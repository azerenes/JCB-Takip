# JCB Tracker - Environment Variables

# --- Security ---
JWT_SECRET=degistirin_bu_sifreyi

# --- Database ---
MONGODB_URI=mongodb://mongo:27017/jcb_tracker

# --- Initial Admin (only used if REQUIRE_SETUP=false) ---
ADMIN_EMAIL=admin@jcbtracker.com
ADMIN_PASSWORD=admin123

# --- Domain (Caddy SSL icin) ---
DOMAIN=localhost
CADDY_EMAIL=admin@jcbtracker.com
SERVER_URL=http://localhost:3000

# --- Setup Mode ---
# true: Ilk calistirmada setup sihirbazi acilir (oneri)
# false: Otomatik admin + demo tenant olusur
REQUIRE_SETUP=true

# --- MQTT ---
MQTT_BROKER=mqtt://emqx:1883
MQTT_WS_BROKER=ws://emqx:8083
MQTT_PORT=1883

# --- SMTP (opsiyonel) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@jcbtracker.com

# --- Simulator (sadece gelistirme) ---
SIM_DEVICE_COUNT=12
SIM_INTERVAL_MS=10000

# --- Timezone ---
TZ=Europe/Istanbul
