# JCB Tracker Ortam Değişkenleri
# Bu dosyayı kopyalayıp .env olarak kaydedin

# JWT Secret (MUTLAKA değiştirin!)
JWT_SECRET=jcb_tracker_production_secret_degistirin

# Admin hesabı
ADMIN_EMAIL=admin@jcbtracker.com
ADMIN_PASSWORD=admin123

# Simülatör ayarları (opsiyonel)
SIM_DEVICE_COUNT=12
SIM_INTERVAL_MS=10000
