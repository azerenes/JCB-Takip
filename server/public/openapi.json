{
  "openapi": "3.0.3",
  "info": { "title": "JCB Tracker API", "version": "2.0.0", "description": "JCB Tracker - İş Makineleri Takip Sistemi REST API" },
  "servers": [{ "url": "/api", "description": "API Sunucusu" }],
  "components": {
    "securitySchemes": { "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" } },
    "schemas": {
      "Device": {
        "type": "object",
        "properties": {
          "deviceId": { "type": "string" }, "name": { "type": "string" }, "plate": { "type": "string" },
          "group": { "type": "string" }, "status": { "type": "string", "enum": ["active","inactive","maintenance"] },
          "apiKey": { "type": "string" }, "tenantId": { "type": "string", "nullable": true },
          "lastLocation": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" }, "speed": { "type": "number" }, "updatedAt": { "type": "string", "format": "date-time" } } }
        }
      },
      "Alert": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" }, "deviceId": { "type": "string" },
          "type": { "type": "string", "enum": ["geofence_enter","geofence_exit","speed_exceeded","battery_low","disconnected"] },
          "severity": { "type": "string", "enum": ["info","warning","critical"] },
          "message": { "type": "string" }, "acknowledged": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "Tenant": { "type": "object", "properties": { "_id": { "type": "string" }, "companyName": { "type": "string" }, "contactEmail": { "type": "string" }, "license": { "type": "object" }, "stats": { "type": "object" } } }
    }
  },
  "paths": {
    "/auth/login": {
      "post": { "tags": ["Kimlik Doğrulama"], "summary": "Kullanıcı girişi", "requestBody": { "content": { "application/json": { "schema": { "type": "object", "properties": { "email": { "type": "string" }, "password": { "type": "string" } }, "required": ["email","password"] } } } }, "responses": { "200": { "description": "JWT token döner" }, "401": { "description": "Geçersiz kimlik" } } }
    },
    "/auth/me": {
      "get": { "tags": ["Kimlik Doğrulama"], "summary": "Mevcut kullanıcı bilgisi", "security": [{ "bearerAuth": [] }], "responses": { "200": { "description": "Kullanıcı profili" } } },
      "put": { "tags": ["Kimlik Doğrulama"], "summary": "Profili güncelle", "security": [{ "bearerAuth": [] }], "responses": { "200": { "description": "Güncellendi" } } }
    },
    "/device": {
      "get": { "tags": ["Cihazlar"], "summary": "Cihazları listele", "security": [{ "bearerAuth": [] }], "parameters": [
        { "in": "query", "name": "group", "schema": { "type": "string" } },
        { "in": "query", "name": "status", "schema": { "type": "string" } },
        { "in": "query", "name": "search", "schema": { "type": "string" } }
      ], "responses": { "200": { "description": "Cihaz listesi", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Device" } } } } } } }
    },
    "/device/{deviceId}": {
      "get": { "tags": ["Cihazlar"], "summary": "Cihaz detayı", "security": [{ "bearerAuth": [] }], "parameters": [{ "in": "path", "name": "deviceId", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Cihaz bilgisi" } } },
      "put": { "tags": ["Cihazlar"], "summary": "Cihaz güncelle", "security": [{ "bearerAuth": [] }], "parameters": [{ "in": "path", "name": "deviceId", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Güncellendi" } } },
      "delete": { "tags": ["Cihazlar"], "summary": "Cihaz sil", "security": [{ "bearerAuth": [] }], "parameters": [{ "in": "path", "name": "deviceId", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Silindi" } } }
    },
    "/device/register": {
      "post": { "tags": ["Cihazlar"], "summary": "Yeni cihaz kaydet (M2M)", "requestBody": { "content": { "application/json": { "schema": { "type": "object", "properties": { "deviceId": { "type": "string" }, "name": { "type": "string" }, "plate": { "type": "string" }, "group": { "type": "string" } }, "required": ["deviceId","name"] } } } }, "responses": { "201": { "description": "Cihaz kaydedildi, apiKey döner" } } }
    },
    "/device/location": {
      "post": { "tags": ["Cihaz Verisi"], "summary": "Anlık konum gönder (M2M)", "requestBody": { "content": { "application/json": { "schema": { "type": "object", "properties": { "deviceId": { "type": "string" }, "apiKey": { "type": "string" }, "lat": { "type": "number" }, "lng": { "type": "number" }, "speed": { "type": "number" }, "timestamp": { "type": "number" } }, "required": ["deviceId","apiKey","lat","lng"] } } } }, "responses": { "200": { "description": "Konum kaydedildi" } } }
    },
    "/panel/summary": {
      "get": { "tags": ["Panel"], "summary": "Dashboard özeti", "security": [{ "bearerAuth": [] }], "responses": { "200": { "description": "İstatistikler" } } }
    },
    "/panel/devices-live": {
      "get": { "tags": ["Panel"], "summary": "Canlı cihaz listesi", "security": [{ "bearerAuth": [] }], "parameters": [{ "in": "query", "name": "group", "schema": { "type": "string" } }], "responses": { "200": { "description": "Cihaz listesi" } } }
    },
    "/panel/alerts": {
      "get": { "tags": ["Uyarılar"], "summary": "Uyarıları listele", "security": [{ "bearerAuth": [] }], "parameters": [
        { "in": "query", "name": "deviceId", "schema": { "type": "string" } },
        { "in": "query", "name": "severity", "schema": { "type": "string" } },
        { "in": "query", "name": "acknowledged", "schema": { "type": "string" } },
        { "in": "query", "name": "limit", "schema": { "type": "integer" } }
      ], "responses": { "200": { "description": "Uyarı listesi", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Alert" } } } } } } }
    },
    "/panel/alerts/{id}/acknowledge": {
      "put": { "tags": ["Uyarılar"], "summary": "Uyarıyı onayla", "security": [{ "bearerAuth": [] }], "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Onaylandı" } } }
    },
    "/reports/device-report/{deviceId}": {
      "get": { "tags": ["Raporlar"], "summary": "Cihaz raporu (JSON/CSV/PDF)", "security": [{ "bearerAuth": [] }], "parameters": [
        { "in": "path", "name": "deviceId", "required": true, "schema": { "type": "string" } },
        { "in": "query", "name": "start", "schema": { "type": "integer" } },
        { "in": "query", "name": "end", "schema": { "type": "integer" } },
        { "in": "query", "name": "format", "schema": { "type": "string", "enum": ["json","csv","pdf"] } }
      ], "responses": { "200": { "description": "Rapor" } } }
    },
    "/superadmin/tenants": {
      "get": { "tags": ["Super Admin"], "summary": "Tenantları listele", "security": [{ "bearerAuth": [] }], "responses": { "200": { "description": "Tenant listesi" } } },
      "post": { "tags": ["Super Admin"], "summary": "Yeni tenant oluştur", "security": [{ "bearerAuth": [] }], "responses": { "201": { "description": "Oluşturuldu" } } }
    },
    "/superadmin/dashboard": {
      "get": { "tags": ["Super Admin"], "summary": "Sistem istatistikleri", "security": [{ "bearerAuth": [] }], "responses": { "200": { "description": "Dashboard verisi" } } }
    },
    "/superadmin/licenses/generate": {
      "post": { "tags": ["Lisans"], "summary": "Lisans anahtarı üret", "security": [{ "bearerAuth": [] }], "requestBody": { "content": { "application/json": { "schema": { "type": "object", "properties": { "count": { "type": "integer" }, "type": { "type": "string" }, "deviceLimit": { "type": "integer" }, "userLimit": { "type": "integer" } } } } } }, "responses": { "201": { "description": "Lisans anahtarları" } } }
    },
    "/config/{deviceId}": {
      "get": { "tags": ["Yapılandırma"], "summary": "Cihaz yapılandırması", "security": [{ "bearerAuth": [] }], "parameters": [{ "in": "path", "name": "deviceId", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Yapılandırma" } } },
      "put": { "tags": ["Yapılandırma"], "summary": "Cihaz yapılandırmasını güncelle", "security": [{ "bearerAuth": [] }], "responses": { "200": { "description": "Güncellendi" } } }
    },
    "/eld/daily/{deviceId}": {
      "get": { "tags": ["ELD"], "summary": "Günlük ELD kayıtları", "security": [{ "bearerAuth": [] }], "parameters": [
        { "in": "path", "name": "deviceId", "required": true, "schema": { "type": "string" } },
        { "in": "query", "name": "date", "schema": { "type": "string" } }
      ], "responses": { "200": { "description": "ELD verisi" } } }
    },
    "/anomaly": {
      "get": { "tags": ["Anomali"], "summary": "Anomalileri listele", "security": [{ "bearerAuth": [] }], "parameters": [
        { "in": "query", "name": "deviceId", "schema": { "type": "string" } },
        { "in": "query", "name": "severity", "schema": { "type": "string" } },
        { "in": "query", "name": "limit", "schema": { "type": "integer" } }
      ], "responses": { "200": { "description": "Anomali listesi" } } }
    },
    "/users": {
      "get": { "tags": ["Kullanıcılar"], "summary": "Kullanıcıları listele", "security": [{ "bearerAuth": [] }], "responses": { "200": { "description": "Kullanıcı listesi" } } },
      "post": { "tags": ["Kullanıcılar"], "summary": "Kullanıcı oluştur", "security": [{ "bearerAuth": [] }], "responses": { "201": { "description": "Oluşturuldu" } } }
    },
    "/setup/status": {
      "get": { "tags": ["Sistem"], "summary": "Kurulum durumu", "responses": { "200": { "description": "Kurulum durumu" } } }
    },
    "/setup/info": {
      "get": { "tags": ["Sistem"], "summary": "Sistem bilgisi", "responses": { "200": { "description": "Sistem bilgisi" } } }
    },
    "/firmware/config/{deviceId}": {
      "get": { "tags": ["Firmware"], "summary": "ESP32 yapılandırma dosyası", "security": [{ "bearerAuth": [] }], "parameters": [{ "in": "path", "name": "deviceId", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Yapılandırma JSON" } } }
    },
    "/health": {
      "get": { "tags": ["Sistem"], "summary": "Sunucu sağlık kontrolü", "responses": { "200": { "description": "Sağlık durumu" } } }
    }
  }
}
